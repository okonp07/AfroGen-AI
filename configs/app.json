{
  "app": {
    "title": "AfroGen-AI MVP",
    "image_size": 512,
    "latent_shape": [4, 4],
    "export_dir": "outputs",
    "backend": "synthetic"
  },
  "dataset": {
    "raw_dir": "data/raw",
    "processed_dir": "data/processed",
    "manifest_path": "data/processed/manifest.jsonl",
    "image_extensions": [".jpg", ".jpeg", ".png", ".webp"],
    "slice_registry_path": "data/processed/slice_registry.json",
    "curation_batch_dir": "data/raw/batches"
  },
  "training": {
    "artifacts_dir": "models",
    "default_manifest_path": "data/processed/manifest.jsonl",
    "future_backends": ["synthetic", "diffusion", "hybrid"],
    "target_backend": "hybrid",
    "model_strategy": "latent-diffusion-plus-editor",
    "dataset_slice_name": "phase3_research_v1",
    "baseline_model_family": "sdxl-lora-plus-latent-editor",
    "minimum_train_records": 5000,
    "minimum_validation_records": 500,
    "run_plan_path": "models/training_run_plan.json",
    "artifact_stub_path": "models/trained_backend_stub.json"
  }
}
